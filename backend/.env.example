# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/jobscraper

# Redis
REDIS_URL=redis://localhost:6379/0

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=masterKey

# Email (local MailHog — http://localhost:8025 to read captured mail)
SMTP_HOST=localhost
SMTP_PORT=1025
FROM_EMAIL=alerts@jobscraper.local

# API
SECRET_KEY=change-me-in-production
ADMIN_TOKEN=change-me-admin-token

# Scraper settings
SCRAPER_REQUEST_DELAY_SECONDS=2
SCRAPER_MAX_RETRIES=3
SCRAPER_TIMEOUT_SECONDS=30

# Base URL for RSS feed links and email alert links
BASE_URL=http://localhost:3000

# Optional: proxy rotation
# HTTP_PROXY=http://user:pass@proxy:port
